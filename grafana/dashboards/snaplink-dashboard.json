{
  "dashboard": {
    "title": "SnapLink Dashboard",
    "uid": "snaplink-main",
    "panels": [
      {
        "title": "Redirects Per Second",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "rate(snaplink_redirects_total_total[1m])",
            "legendFormat": "Redirects/sec"
          }
        ]
      },
      {
        "title": "Redirect Latency (p50, p95, p99)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "snaplink_redirect_latency_seconds{quantile=\"0.5\"}",
            "legendFormat": "p50"
          },
          {
            "expr": "snaplink_redirect_latency_seconds{quantile=\"0.95\"}",
            "legendFormat": "p95"
          },
          {
            "expr": "snaplink_redirect_latency_seconds{quantile=\"0.99\"}",
            "legendFormat": "p99"
          }
        ]
      },
      {
        "title": "Cache Hit Ratio",
        "type": "gauge",
        "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
        "targets": [
          {
            "expr": "snaplink_cache_hits_total / (snaplink_cache_hits_total + snaplink_cache_misses_total)",
            "legendFormat": "Hit Ratio"
          }
        ]
      },
      {
        "title": "Rate Limit Rejections",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
        "targets": [
          {
            "expr": "rate(snaplink_ratelimit_rejected_total[1m])",
            "legendFormat": "Rejections/sec"
          }
        ]
      },
      {
        "title": "URLs Created",
        "type": "stat",
        "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
        "targets": [
          {
            "expr": "snaplink_urls_created_total",
            "legendFormat": "Total URLs"
          }
        ]
      }
    ],
    "time": { "from": "now-1h", "to": "now" },
    "refresh": "5s"
  }
}
